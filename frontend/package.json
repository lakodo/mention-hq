    "@mantine/spotlight": "^8.0.0",
    "@tabler/icons-react": "^3.26.0",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
