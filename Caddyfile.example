# Template. Copy it to `Caddyfile` (gitignored) and set your own name:
#
#   cp Caddyfile.example Caddyfile
#   # edit the domain below, then add it to your hosts file:
#   echo "127.0.0.1 myhq" | sudo tee -a /etc/hosts
#
# It serves the whole app under one bare domain. Run the two dev servers (`task dev`) and
# this proxy (`task proxy`) side by side. /api goes to the API, everything else to Vite (the
# SPA and its hot-reload socket), so the page and its API calls share one origin — no CORS.
#
# http:// keeps Caddy on port 80 with no TLS — a made-up local name has no real certificate.

http://myhq {
	handle /api/* {
		reverse_proxy localhost:13000
	}

	handle {
		reverse_proxy localhost:13001
	}
}
