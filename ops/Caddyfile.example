# Template. `task proxy:set` copies this to ops/Caddyfile (gitignored) with your chosen
# domain filled in — you don't edit this file by hand.
#
# It serves the whole app under one bare local domain. Run the two dev servers (`task dev`)
# and the proxy (`task proxy`) side by side. /api goes to the API, everything else to Vite
# (the SPA and its hot-reload socket), so the page and its API calls share one origin — no
# CORS.
#
# `tls internal` serves HTTPS with Caddy's own local CA: a made-up name has no public
# certificate, so Caddy mints one and installs its root into your system trust store the
# first time (one sudo prompt). The browser then shows a real padlock — which is also what
# lets strict OAuth providers accept an https://<domain>/... redirect URI.

https://__DOMAIN__ {
	tls internal

	handle /api/* {
		reverse_proxy localhost:13000
	}

	handle {
		reverse_proxy localhost:13001
	}
}
